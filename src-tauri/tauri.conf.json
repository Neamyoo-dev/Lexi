{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lexi 输入法",
  "version": "0.1.0",
  "identifier": "cn.neamyoo.lexi",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Lexi 设置",
        "label": "settings",
        "width": 480,
        "height": 560,
        "decorations": false,
        "alwaysOnTop": false,
        "transparent": true,
        "visible": false,
        "resizable": false,
        "skipTaskbar": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
